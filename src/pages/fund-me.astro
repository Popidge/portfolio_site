---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const BTC_ADDRESS = 'bc1qxrnftdp5ep92zsx70qzhmy3gzpv95dkhkl89x0';

const tiers = [
  {
    code: 'API-001',
    price: '$10',
    label: 'Emergency Tokens',
    desc: 'I ran a ralph loop again.',
    color: 'var(--color-vhs-cinnabar)',
  },
  {
    code: 'API-002',
    price: '$20',
    label: 'Top-Up',
    desc: 'One slightly-too-long Codex goal.',
    color: 'var(--color-vhs-gold)',
  },
  {
    code: 'API-003',
    price: '$50',
    label: 'Compute Credit',
    desc: 'Fine-tuned something. Regrets pending.',
    color: 'var(--color-vhs-ocean)',
  },
  {
    code: 'GPT-5X',
    price: '$100',
    label: 'ChatGPT Pro 5x',
    desc: 'One month of GPT-5.5 access. I promise to use it wisely.',
    color: 'var(--color-vhs-cinnabar)',
  },
  {
    code: 'GPT-20X',
    price: '$200',
    label: 'ChatGPT Pro 20x',
    desc: 'The full OpenAI experience. Tibo would be proud.',
    color: 'var(--color-vhs-gold)',
  },
  {
    code: 'CLA-MAX',
    price: '$200',
    label: 'Claude Max',
    desc: 'One month of Claude Max. I need the Fable 5 tokens.',
    color: 'var(--color-vhs-ocean)',
  },
];

---

<BaseLayout
  title="Fund Me — Jamie Taylor"
  description="Digital begging for the sheer cheek of it. Support my crippling AI coding addiction."
>
  <div class="h-screen bg-[var(--bg-primary)] text-[var(--text-primary)] relative overflow-hidden flex flex-col">
    <!-- Analog noise overlay -->
    <div class="fixed inset-0 pointer-events-none z-50 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E');"></div>

    <!-- Scanlines -->
    <div class="fixed inset-0 pointer-events-none z-40" style="background: repeating-linear-gradient(0deg, rgba(0,0,0,0.1) 0px, transparent 1px, transparent 2px); background-size: 100% 4px;"></div>

    <Navigation currentPath="/fund-me" />

    <!-- MAIN CONTENT -->
    <main class="flex-1 pt-16 px-4 md:px-8 relative z-10 flex flex-col min-h-0">
      <div class="max-w-7xl mx-auto w-full flex flex-col gap-3 flex-1 min-h-0">

        <!-- HEADER -->
        <div class="flex items-center justify-between border-b-2 border-[var(--text-muted)]/30 pb-2 shrink-0">
          <div class="flex items-center gap-4">
            <span class="font-['JetBrains_Mono'] text-xs text-[var(--text-muted)]">FUNDING:</span>
            <span class="font-['Inter'] font-black text-xl text-[var(--text-primary)] tracking-wider">AI-FUND-001</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-['Noto_Sans_JP'] text-xs text-[var(--text-muted)]">寄付</span>
            <span class="px-2 py-0.5 bg-[var(--color-vhs-cinnabar)] text-white font-['Inter'] font-bold text-xs">DONATE</span>
          </div>
        </div>

        <!-- TITLE + PITCH -->
        <div class="shrink-0 flex items-start gap-6">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <div class="flex gap-0.5">
                {[...Array(5)].map((_, i) => (
                  <span class="w-2 h-2 rounded-full bg-[var(--color-vhs-cinnabar)]"></span>
                ))}
              </div>
              <span class="font-['Noto_Sans_JP'] text-xs text-[var(--color-vhs-cinnabar)]">プロフェッショナル</span>
            </div>
            <h1 class="font-['Inter'] font-black text-3xl text-[var(--text-primary)] uppercase leading-none tracking-tight">
              DIGITAL BEGGING FOR THE CHEEK
            </h1>
            <p class="font-['Inter'] text-sm text-[var(--text-secondary)] mt-1 max-w-2xl">
              I make fun, occasionally useful, often daft things with AI. Part <em class="text-[var(--color-vhs-gold)]">"notice me, here's my resume"</em>, part <em class="text-[var(--color-vhs-gold)]">"digital begging for the sheer cheek of it"</em>. You clicked the link, you're curious - now support the cheek.
            </p>
          </div>
          <div class="text-right shrink-0 hidden md:block">
            <span class="font-['Noto_Sans_JP'] text-xs text-[var(--text-muted)] block">乞食</span>
            <span class="font-['JetBrains_Mono'] text-xs text-[var(--color-vhs-cinnabar)]">STATUS: ADDICTED</span>
          </div>
        </div>

        <!-- MAIN BODY: TIERS + PAYMENT -->
        <div class="flex-1 min-h-0 grid grid-cols-1 lg:grid-cols-5 gap-3">

          <!-- TIERS (3 cols) -->
          <div class="lg:col-span-3 flex flex-col min-h-0">
            <div class="flex items-center justify-between mb-2 border-b border-[var(--text-muted)]/30 pb-1 shrink-0">
              <span class="font-['JetBrains_Mono'] text-xs text-[var(--text-muted)]">THINGS I'LL SPEND THE MONEY ON</span>
              <span class="font-['JetBrains_Mono'] text-xs text-[var(--text-muted)]">DEFINITELY NOT BEER</span>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-2 flex-1 min-h-0">
              {tiers.map((tier, index) => (
                <div class="bg-[var(--bg-card)] border border-[var(--text-muted)]/30 hover:border-[var(--color-vhs-gold)] transition-colors flex flex-col">
                  <div class="border-b border-[var(--text-muted)]/30 p-2 flex justify-between items-center bg-[var(--bg-secondary)]">
                    <span class="font-['JetBrains_Mono'] text-[10px] text-[var(--color-vhs-ocean)]">{tier.code}</span>
                    <span class="font-['Inter'] font-black text-base text-[var(--text-primary)]">{tier.price}</span>
                  </div>
                  <div class="p-2 flex-1 flex flex-col">
                    <h3 class="font-['Inter'] font-bold text-sm text-[var(--text-primary)] uppercase leading-tight">
                      {tier.label}
                    </h3>
                    <p class="font-['Inter'] text-xs text-[var(--text-secondary)] leading-tight flex-1">
                      {tier.desc}
                    </p>
                    <div class="h-1 w-full mt-1" style={`background: ${tier.color}`}></div>
                  </div>
                </div>
              ))}
            </div>
            <p class="font-['Noto_Sans_JP'] text-[10px] text-[var(--text-muted)] mt-1 text-right shrink-0">
              ※すべての寄付は非課税の感謝の気持ちとして受け取られます
            </p>
          </div>

          <!-- PAYMENT + CONTACT (2 cols) -->
          <div class="lg:col-span-2 flex flex-col gap-3 min-h-0">

            <!-- PAYMENT TERMINAL -->
            <div class="bg-[var(--bg-card)] border border-[var(--text-muted)]/30 p-3 flex flex-col min-h-0 flex-1">
              <div class="flex items-center gap-2 mb-2 border-b border-[var(--text-muted)]/20 pb-1 shrink-0">
                <span class="font-['JetBrains_Mono'] text-xs text-[var(--text-muted)]">PAYMENT TERMINAL</span>
              </div>

              <div class="flex flex-col gap-3 flex-1 min-h-0">
                <!-- BTC -->
                <div class="flex flex-col items-center gap-2">
                  <div class="bg-white p-2 rounded">
                    <img
                      src="/btc-qr.svg"
                      alt="Bitcoin QR code"
                      class="w-28 h-28"
                    />
                  </div>
                  <div class="w-full">
                    <div class="flex items-center justify-between mb-1">
                      <span class="font-['JetBrains_Mono'] text-[12px] text-[var(--text-muted)]">BTC</span>
                      <button
                        id="copy-btc"
                        class="font-['JetBrains_Mono'] text-[12px] text-[var(--color-vhs-ocean)] hover:text-[var(--color-vhs-gold)] transition-colors"
                        data-address={BTC_ADDRESS}
                      >
                        [COPY]
                      </button>
                    </div>
                    <div class="bg-[var(--bg-primary)] border border-[var(--text-muted)]/30 p-1.5 overflow-x-auto">
                      <code class="font-['JetBrains_Mono'] text-[10px] text-[var(--color-vhs-gold)] whitespace-nowrap">
                        {BTC_ADDRESS}
                      </code>
                    </div>
                    <span id="copy-feedback" class="font-['JetBrains_Mono'] text-[10px] text-[var(--color-vhs-gold)] mt-1 block opacity-0 transition-opacity">
                      COPIED TO CLIPBOARD
                    </span>
                  </div>
                </div>

                <!-- PayPal -->
                <div class="border-t border-[var(--text-muted)]/20 pt-2">
                  <div class="flex items-center justify-between">
                    <div>
                      <span class="font-['JetBrains_Mono'] text-[10px] text-[var(--text-muted)] block">FIAT</span>
                      <span class="font-['Inter'] font-bold text-sm text-[var(--text-primary)]">PayPal</span>
                    </div>
                    <a
                      href="https://paypal.me/popidge"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 bg-[var(--color-vhs-ocean)] text-white px-4 py-2 font-['Inter'] font-bold text-sm uppercase tracking-wider hover:bg-[var(--color-vhs-gold)] transition-colors"
                    >
                      <span>PayPal.me/popidge</span>
                      <span class="font-['JetBrains_Mono'] text-xs">→</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- CONTACT -->
            <div class="bg-[var(--bg-card)] border border-[var(--text-muted)]/30 p-3 shrink-0">
              <div class="flex items-center gap-2 mb-2 border-b border-[var(--text-muted)]/20 pb-1">
                <span class="font-['JetBrains_Mono'] text-xs text-[var(--text-muted)]">ALTERNATIVE</span>
                <span class="font-['JetBrains_Mono'] text-xs text-[var(--color-vhs-gold)]">HIRE ME INSTEAD</span>
              </div>
              <div class="flex gap-2">
                <a
                  href="mailto:jamie@jt-ai.dev"
                  class="flex-1 text-center py-2 border border-[var(--text-primary)] text-[var(--text-primary)] font-['JetBrains_Mono'] text-xs hover:bg-[var(--text-primary)] hover:text-[var(--bg-primary)] transition-colors"
                >
                  Email
                </a>
                <a
                  href="https://github.com/popidge"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 text-center py-2 border border-[var(--text-muted)] text-[var(--text-secondary)] font-['JetBrains_Mono'] text-xs hover:border-[var(--color-vhs-gold)] hover:text-[var(--color-vhs-gold)] transition-colors"
                >
                  GitHub
                </a>
                <a
                  href="https://www.linkedin.com/in/jamie-taylor-52914950/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 text-center py-2 border border-[var(--text-muted)] text-[var(--text-secondary)] font-['JetBrains_Mono'] text-xs hover:border-[var(--color-vhs-gold)] hover:text-[var(--color-vhs-gold)] transition-colors"
                >
                  LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- 3-COLOR STRIPE -->
        <div class="flex gap-0 h-2 shrink-0">
          <div class="flex-1 bg-[var(--color-vhs-cinnabar)]"></div>
          <div class="flex-1 bg-[var(--color-vhs-ocean)]"></div>
          <div class="flex-1 bg-[var(--color-vhs-gold)]"></div>
        </div>

      </div>
    </main>

    <!-- COMPACT FOOTER -->
    <footer class="bg-[var(--bg-primary)] text-[var(--text-primary)] py-2 px-4 md:px-8 relative z-10 border-t border-[var(--text-muted)]/10 shrink-0">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <p class="font-['JetBrains_Mono'] text-[10px] text-[var(--text-muted)]">
          © 2026 // JT-DEV-001 // LOUGHBOROUGH, UK
        </p>
        <p class="font-['Noto_Sans_JP'] text-[10px] text-[var(--text-muted)]">
          プロフェッショナル録画再生
        </p>
      </div>
    </footer>
  </div>

  <script>
    const copyBtn = document.getElementById('copy-btc');
    const feedback = document.getElementById('copy-feedback');

    if (copyBtn && feedback) {
      copyBtn.addEventListener('click', async () => {
        const address = copyBtn.dataset.address;
        if (!address) return;

        try {
          await navigator.clipboard.writeText(address);
          feedback.classList.remove('opacity-0');
          setTimeout(() => {
            feedback.classList.add('opacity-0');
          }, 2000);
        } catch (err) {
          const textArea = document.createElement('textarea');
          textArea.value = address;
          document.body.appendChild(textArea);
          textArea.select();
          document.execCommand('copy');
          document.body.removeChild(textArea);
          feedback.classList.remove('opacity-0');
          setTimeout(() => {
            feedback.classList.add('opacity-0');
          }, 2000);
        }
      });
    }
  </script>
</BaseLayout>
